# =============================================================================
# LPLAN Central - Variáveis de ambiente (copie para .env e preencha)
# =============================================================================

# --- Obrigatório em produção ---
SECRET_KEY=sua-chave-secreta-longa-e-aleatoria
DEBUG=False
ALLOWED_HOSTS=sistema.lplan.com.br,localhost,127.0.0.1

# --- Produção HTTPS (evita "Sessão inválida" em POSTs no Mapa de Suprimentos) ---
# Use True se o site for acessado por https://
SECURE_COOKIES_AND_REDIRECT=True
# Origens permitidas para CSRF (URL exata do site, sem barra no final)
# Se usar só HTTPS, coloque uma linha. Se tiver HTTP e HTTPS, separe por vírgula.
CSRF_TRUSTED_ORIGINS=https://sistema.lplan.com.br

# --- Banco (produção cPanel / MySQL) ---
USE_MYSQL=True
DB_NAME=lplan_Sistema
DB_USER=lplan_gestaoap2
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# --- Cookies (opcional; deixe vazio para usar o host da requisição) ---
# Só preencha se usar vários subdomínios (ex: .lplan.com.br)
# SESSION_COOKIE_DOMAIN=
# CSRF já usa o mesmo valor via settings

# --- E-mail (produção) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=sistema@lplan.com.br
SITE_URL=https://sistema.lplan.com.br

# --- E-mail RDO (Relatório Diário de Obras; opcional) ---
# Se definidos, os e-mails de diário de obra saem desta conta (ex.: rdo@lplan.com.br)
# EMAIL_RDO_FROM=rdo@lplan.com.br
# EMAIL_RDO_HOST_USER=rdo@lplan.com.br
# EMAIL_RDO_HOST_PASSWORD=
# Opcional: EMAIL_RDO_HOST, EMAIL_RDO_PORT, EMAIL_RDO_USE_SSL (padrão: mesmo do E-mail acima)

# --- Gestão de Aprovação ---
EMAIL_DEPARTAMENTOS_APROVACAO=luiz.henrique@lplan.com.br,luizdomingos@lplan.com.br

# --- Sienge (Mapa de Suprimentos; opcional) ---
# SIENGE_API_BASE_URL=https://api.sienge.com.br
# SIENGE_API_CLIENT_ID=
# SIENGE_API_CLIENT_SECRET=
# SIENGE_WEBHOOK_SECRET=

# --- Celery (opcional) ---
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
